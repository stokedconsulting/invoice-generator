{
  "version": "1.0.0",
  "global": {
    "defaultFromEmail": "you@example.com",
    "defaultBcc": []
  },
  "invoices": [
    {
      "id": "example-biweekly",
      "name": "Example Bi-Weekly Invoice",
      "customer": "Acme Corp",
      "enabled": false,
      "schedule": {
        "type": "bi-weekly-sunday",
        "startDate": "2024-01-07"
      },
      "email": {
        "to": ["billing@example.com"],
        "cc": [],
        "subject": "Invoice for {{customer}} from {{startDate}} - {{endDate}}",
        "fromName": "Your Name"
      },
      "git": {
        "repos": ["org/repo-name"],
        "repoDirs": ["/path/to/local/repos*"],
        "weeks": 2,
        "hoursPerWeek": 40
      },
      "ai": {
        "enabled": true,
        "codeAnalysis": {
          "enabled": true
        },
        "lineItemGeneration": {
          "enabled": true
        }
      }
    }
  ]
}
